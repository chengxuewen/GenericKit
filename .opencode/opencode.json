{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "mem0": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "mem0ai/mem0"],
      "env": {
        "MEM0_DIR": ".agents/GenericKit-Agent-Memory",
        "MEMORY_DB_PATH": ".agents/GenericKit-Agent-Memory/memory.sqlite"
      }
    }
  }
}