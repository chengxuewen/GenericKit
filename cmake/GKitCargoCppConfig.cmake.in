@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(NOT TARGET @FFI_BASE_NAME@)
	find_dependency(@FFI_BASE_NAME@)
endif()

set(_gkit_prefix "${CMAKE_CURRENT_LIST_DIR}/../../..")

add_library(@BASE_NAME@ INTERFACE)
target_include_directories(@BASE_NAME@ INTERFACE "${_gkit_prefix}/@GKIT_INCLUDEDIR@")
target_link_libraries(@BASE_NAME@ INTERFACE @FFI_BASE_NAME@)
